# === Server ===
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=True

# === Database - InfluxDB ===
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=landslide-org
INFLUXDB_BUCKET=sensor_data

# === Database - PostgreSQL ===
POSTGRES_URL=postgresql://user:password@localhost:5432/landslide_db

# === Fallback - SQLite (dùng khi không có PostgreSQL) ===
USE_SQLITE=True
SQLITE_PATH=data/landslide.db

# === MQTT ===
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=sensors/+/data
MQTT_USERNAME=
MQTT_PASSWORD=

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# === Email ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_TO=recipient@example.com

# === Ngưỡng cảnh báo ===
THRESHOLD_SOIL_MOISTURE_WARNING=70
THRESHOLD_SOIL_MOISTURE_ALERT=85
THRESHOLD_SOIL_MOISTURE_CRITICAL=95

THRESHOLD_RAINFALL_WARNING=30
THRESHOLD_RAINFALL_ALERT=50
THRESHOLD_RAINFALL_CRITICAL=80

THRESHOLD_VIBRATION_WARNING=0.5
THRESHOLD_VIBRATION_ALERT=1.0
THRESHOLD_VIBRATION_CRITICAL=2.0

THRESHOLD_TILT_ANGLE_WARNING=5
THRESHOLD_TILT_ANGLE_ALERT=10
THRESHOLD_TILT_ANGLE_CRITICAL=15

THRESHOLD_PORE_PRESSURE_WARNING=50
THRESHOLD_PORE_PRESSURE_ALERT=80
THRESHOLD_PORE_PRESSURE_CRITICAL=100

# === Alert ===
ALERT_COOLDOWN_SECONDS=300
